APP_NAME=yt-clipper-api
ENVIRONMENT=local
ENV_FILE=.env
API_KEYS=dev-secret-change-me
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
POSTGRES_DB=ytclipper
POSTGRES_USER=ytclipper
POSTGRES_PASSWORD=ytclipper
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
FRONTEND_PORT=8080
PUBLIC_API_BASE_URL=http://localhost:8000
FRONTEND_API_KEY=dev-secret-change-me
DOWNLOADS_HOST_DIR=./downloads
DATABASE_URL=postgresql+psycopg://ytclipper:ytclipper@postgres:5432/ytclipper
REDIS_URL=redis://redis:6379/0
STORAGE_DIR=/app/downloads
MAX_CLIP_DURATION_SECONDS=14400
YTDLP_SOCKET_TIMEOUT_SECONDS=30
FFMPEG_TIMEOUT_SECONDS=1800
